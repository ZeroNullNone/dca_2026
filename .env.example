# This file is read first. A local .env file, if present, overrides it.
GLASSNODE_API_KEY=
GLASSNODE_ASSET=BTC
BINANCE_SYMBOL=BTCUSDT
DASHBOARD_HISTORY_DAYS=3650
DASHBOARD_CHART_DAYS=1460
SERVER_HOST=127.0.0.1
SERVER_PORT=8765
# Set this on public deployments. Browser writes/deletes must send the same token.
DCA_API_TOKEN=

# Override only if Glassnode changes endpoint paths for your plan.
GLASSNODE_MVRV_Z_PATH=/v1/metrics/market/mvrv_z_score
GLASSNODE_NUPL_PATH=/v1/metrics/indicators/net_unrealized_profit_loss
GLASSNODE_PUELL_PATH=/v1/metrics/indicators/puell_multiple
